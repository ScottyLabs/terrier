server {
    listen 443 ssl http2;
    server_name terrier.scottylabs.org;

    # SSL Configuration
    ssl_certificate     /etc/letsencrypt/live/DVCert/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/DVCert/privkey.pem;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;
    add_header X-XSS-Protection "1; mode=block";

    client_max_body_size 10M;

    # Logging
    access_log /var/log/nginx/terrier.access.log;
    error_log /var/log/nginx/terrier.error.log;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
    }
}

# S3/MinIO server
server {
    listen 443 ssl http2;
    server_name s3.terrier.scottylabs.org;

    # SSL Configuration
    ssl_certificate     /etc/letsencrypt/live/DVCert/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/DVCert/privkey.pem;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options nosniff;

    # Allow larger uploads (100MB for files like resumes, banners, etc.)
    client_max_body_size 100M;

    # Logging
    access_log /var/log/nginx/s3.terrier.access.log;
    error_log /var/log/nginx/s3.terrier.error.log;

    location / {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # MinIO specific headers
        proxy_set_header Connection "";
        chunked_transfer_encoding off;
        proxy_buffering off;
    }
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name terrier.scottylabs.org s3.terrier.scottylabs.org;
    return 301 https://$server_name$request_uri;
}
